@using SimpleOntoDoc
@model MarkdownClassViewModel
@{
    Layout = null;
}

# @Model.Class.Id

@Model.Class.Display  
@Model.Class.Description

@if (Model.Class.Type == ClassType.Enum && Model.Class.Enumerators.Count > 0)
{
<text>
# Перечисление

| Идентификатор | Display  | Описание |
| ---------------| ------- |----------|
</text>
@foreach (var enumerator in Model.Class.Enumerators.Values)
{
@:| @enumerator.NameWithAnchor() | @enumerator.Display | @enumerator.Description |
}
}

# Сводка

| Ключ    | Значение |
|-----------------|------------|
| Тип             | @Model.Class.MarkdownColorSquare() @Model.Class.Type.ToString() |
| namespace       | @Model.Class.Namespace |
@if (Model.Class.Type == ClassType.Class) 
{
@:| Базовый класс | @Model.SubClassString |
}
@if (Model.Class.Type == ClassType.Class
     || Model.Class.Type == ClassType.Compound) 
{
@:| Свойств | @Model.Class.Properties.Count |
}
@if (Model.Class.Type == ClassType.Class) 
{
@:| Всех свойств | @Model.AllClassProperties.Count |
@:| Дочерних классов | @Model.ChildClasses.Count |
}
@if (Model.Class.Type == ClassType.Enum) 
{
@:| Элементов | @Model.Class.Enumerators.Count |
}
| Ссылок       | @Model.LinkProperties.Count |


@if (Model.Class.Type == ClassType.Class)
{
@:# Диаграмма
@if (Model.DiagramWay == DiagramWay.Vanilla)
{
<text>
```plantuml
@Model.Class.DiagramContent
```
</text>
}
else
{
@:[plant-uml:./diagrams/@(Model.Class.Id).puml]
}
}

@if (Model.Properties.Count > 0)
{
<text>
 # Свойства

| Идентификатор  | Тип  | Ограничения | Display  | Описание  |
|----------------|------|------------ |-----------|-----------|
</text>
@foreach(var prop in Model.Properties)
{
@:| @prop.NameWithAnchor() | @prop.Range.MarkdownColorSquare() @prop.Range.MarkdownRef(near: true) | @prop.MarkdownLimits() | @prop.Display | @prop.Description |
}
}

@if (Model.ChildClasses.Count > 0)
{
<text>
# Дочерние классы

| Идентификатор  | Display  | Описание  |
| ---------------| ----------| ----------|
</text>    
@foreach(var child in Model.ChildClasses)
{
@:| @child.MarkdownRef(near: true) | @child.Display | @child.Description |
}
    
}

@if (Model.AllClassProperties.Count > Model.Class.Properties.Count)
{
<text>
# Все свойства (включая унаследованные)

| Идентификатор | Тип   |  Ограничения  | Display   |  Описание |
| ---------------| -----| --------------|  ----------| ----------|
</text>
@foreach(var prop in Model.AllClassProperties)
{
@:| @prop.MarkdownRef() |  @prop.Range.MarkdownColorSquare() @prop.Range.MarkdownRef(near: true) | @prop.MarkdownLimits() | @prop.Display | @prop.Description |
}
}

@if (Model.LinkProperties.Count > 0)
{
<text>
# Ссылки

| Свойство  | Display  | Описание |
| ----------| ----------|----------|
</text>
@foreach(var prop in Model.LinkProperties)
{
@:| @prop.MarkdownRef() | @prop.Display | @prop.Description |
}
}

