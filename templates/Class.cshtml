@using Microsoft.AspNetCore.Html
@using SimpleOntoDoc
@model ClassViewModel
@{
    Layout = "_Layout.cshtml";
}

<h1>@Model.Class.Id <small class="text-muted">@GetTypeBadge(Model.Class.Type)</small></h1>

@if (!string.IsNullOrEmpty(Model.Class.Description))
{
    <p class="lead">@Model.Class.Description</p>
}

<!-- Разметка -->
@if (!string.IsNullOrEmpty(Model.Class.SvgDiagram))
{
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Diagram</h5>
        </div>
        <div class="card-body p-0">
            <div class="diagram-viewport" style="width: 100%; height: 500px; overflow: hidden;">
                <div class="diagram-content">
                    @(new Microsoft.AspNetCore.Html.HtmlString(Model.Class.SvgDiagram))
                </div>
            </div>
        </div>
    </div>
}

<div class="row mt-4">
    <div class="col-lg-8">
        <!-- Свойства класса (только для обычных классов) -->
        @if (Model.Class.Type == ClassType.Class && Model.Properties.Any())
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Свойства (@Model.Properties.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Тип</th>
                                    <th>Описание</th>
                                    <th>Количество</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prop in Model.Properties)
                                {
                                    <tr class="searchable">
                                        <td>
                                            <a href="@Model.BasePath/@prop.Href()" class="text-decoration-none">
                                                @prop.Name
                                            </a>
                                        </td>
                                        <td>
                                            <a href="@Model.BasePath/@prop.Range.Href()" class="badge @(prop.Range.BadgeClass()) text-decoration-none">
                                                @prop.Range.Id
                                            </a>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(prop.Description))
                                            {
                                                <small class="text-muted">@prop.Description</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
  
                                        <td>
                                            @if (!string.IsNullOrEmpty(prop.Multiplicity))
                                            {
                                                <span class="badge bg-info">@prop.Multiplicity</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Элементы перечисления (только для enums) -->
        @if (Model.Class.Type == ClassType.Enum && Model.Class.Enumerators.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Enumeration Values (@Model.Class.Enumerators.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Value</th>
                                    <th>Описание</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var enumerator in Model.Class.Enumerators.Values)
                                {
                                    <tr class="searchable">
                                        <td>
                                            <code>@enumerator.Name</code>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(enumerator.Description))
                                            {
                                                <span>@enumerator.Description</span>
                                            }
                                            else
                                            {
                                                <span>—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Использование (где этот класс используется как range) -->
        @{
            var usedInProperties = Model.AllProperties
            .Where(p => p.Range.Id == Model.Class.Id)
            .ToList();
        }

        @if (usedInProperties.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Ссылки (@usedInProperties.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Класс</th>
                                    <th>Свойство</th>
                                    <th>Описание</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prop in usedInProperties)
                                {
                                    <tr class="searchable">
                                        <td>
                                            <a href="@Model.BasePath/@prop.Domain.Href()" class="badge badge-class text-decoration-none">
                                                @prop.Domain.NamespacedId()
                                            </a>
                                        </td>
                                        <td>
                                            <a href="@Model.BasePath/@prop.Href()" class="badge badge-property text-decoration-none">
                                                @prop.NamespacedId()
                                            </a>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(prop.Description))
                                            {
                                                <p>@prop.Description</p>
                                            }
                                            else
                                            {
                                                <p>—</p>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (Model.ChildClasses.Any())
        {
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Дочерние классы (@Model.ChildClasses.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Класс</th>
                                    <th>Описание</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cls in Model.ChildClasses)
                                {
                                    <tr class="searchable">
                                        <td>
                                            <a href="@Model.BasePath/@cls.Href()" class="badge badge-class text-decoration-none">
                                                @cls.NamespacedId()
                                            </a>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(cls.Description))
                                            {
                                                <p>@cls.Description</p>
                                            }
                                            else
                                            {
                                                <p>—</p>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

    </div>

    <div class="col-lg-4">
        <!-- Информация о классе -->
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">Информация о классе</h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8"><code>@Model.Class.NamespacedId()</code></dd>

                    <dt class="col-sm-4">Тип</dt>
                    <dd class="col-sm-8">@GetTypeBadge(Model.Class.Type)</dd>

                    @if (Model.Class.SubClass != null)
                    {
                        <dt class="col-sm-4">Наследует</dt>
                        <dd class="col-sm-8">
                            <a href="@Model.BasePath/@Model.Class.SubClass.Href()" class="text-decoration-none">
                                @Model.Class.SubClass.NamespacedId()
                            </a>
                        </dd>
                    }

                    @if (Model.Class.Type == ClassType.Class)
                    {
                        <dt class="col-sm-4">Свойств</dt>
                        <dd class="col-sm-8">@Model.Properties.Count</dd>
                    }

                    @if (Model.Class.Type == ClassType.Enum)
                    {
                        <dt class="col-sm-4">Значений</dt>
                        <dd class="col-sm-8">@Model.Class.Enumerators.Count</dd>
                    }
                </dl>
            </div>
        </div>

        <!-- Навигация -->
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">Навигация</h6>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <a href="@Model.BasePath/@Model.Class.Href()" class="list-group-item list-group-item-action">
                        ← All @Model.Breadcrumbs[1].Name
                    </a>
                    @if (Model.Class.SubClass != null)
                    {
                        <a href="@Model.BasePath/@Model.Class.SubClass.Href()"
                           class="list-group-item list-group-item-action">
                            ↑ Parent: @Model.Class.SubClass.NamespacedId()
                        </a>
                    }
                    <a href="@Model.BasePath/index.html" class="list-group-item list-group-item-action">
                        🏠 Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const elem = document.querySelector('.diagram-content');
        const parent = document.querySelector('.diagram-viewport');

        // Обернем SVG в div для лучшего управления
        if (elem.querySelector('svg')) {
            elem.querySelector('svg').style.display = 'block';
        }

        // Инициализируем panzoom
        panzoom(elem, {
            bounds: false,
            boundsPadding: 0.1,
            maxZoom: 50,
            minZoom: 0.01,
            zoomSpeed: 0.1,
            initialZoom: 0.45,
            initialX: 0,
            initialY: 0,
            contain: 'outside',
            smoothScroll: false
        });
    });
</script>

@functions {
    HtmlString GetTypeBadge(ClassType type)
    {
        var displayText = type switch
        {
            ClassType.Class => "Class",
            ClassType.Enum => "Enum",
            ClassType.Primitive => "Primitive",
            ClassType.Datatype => "Data Type",
            ClassType.Compound => "Compound",
            _ => type.ToString().ToUpper()
        };

        return new HtmlString($"<span class=\"badge {ClassExtensions.BadgeClassStatic(type)}\">{displayText}</span>");
    }
}