@using SimpleOntoDoc
@model PropertyViewModel
@{
    Layout = "_Layout.cshtml";
}

<h1>@Model.Property.Id</h1>
@if (!string.IsNullOrEmpty(Model.Property.Name))
{
    <p class="lead">@Model.Property.Name</p>
}

<div class="row mt-4">
    <div class="col-lg-8">
        <!-- Основная информация -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Информация о свойстве</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">ID</dt>
                    <dd class="col-sm-9"><code>@Model.Property.Id</code></dd>

                    <dt class="col-sm-3">Класс</dt>
                    <dd class="col-sm-9">
                        <a href="/@Model.Property.Domain.Href()" class="text-decoration-none">
                            <span class="badge @(Model.Property.Domain.BadgeClass())">@Model.Property.Domain.NamespacedId()</span>
                        </a>
                        @if (!string.IsNullOrEmpty(Model.Property.Domain.Name))
                        {
                            <small class="text-muted d-block mt-1">@Model.Property.Domain.Name</small>
                        }
                    </dd>

                    <dt class="col-sm-3">Тип</dt>
                    <dd class="col-sm-9">
                        <a href="/@Model.Property.Range.Href()" class="text-decoration-none">
                            <span class="badge @(Model.Property.Range.BadgeClass())">@Model.Property.Range.NamespacedId()</span>
                        </a>
                        @if (!string.IsNullOrEmpty(Model.Property.Range.Name))
                        {
                            <small class="text-muted d-block mt-1">@Model.Property.Range.Name</small>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Property.Multiplicity))
                    {
                        <dt class="col-sm-3">Количество</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-info">@Model.Property.Multiplicity</span>
                        </dd>
                    }

                    @if (!string.IsNullOrEmpty(Model.Property.InverseRoleName))
                    {
                        <dt class="col-sm-3">Обратное свойство</dt>
                        <dd class="col-sm-9">
                            <a href="/properties/@(Model.Property.InverseRoleName).html" class="text-decoration-none">
                                <code>@Model.Property.InverseRoleName</code>
                            </a>
                        </dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Навигация -->
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">Навигация</h6>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a href="/@Model.Property.Domain.Href()"
                       class="list-group-item list-group-item-action">
                        ← Назад к классу
                    </a>
                    <a href="/properties/_index.html"
                       class="list-group-item list-group-item-action">
                        📋 Все свойства
                    </a>
                    <a href="/@Model.Property.Range.Href()"
                       class="list-group-item list-group-item-action">
                        → Перейти к типу
                    </a>
                </div>
            </div>
        </div>

        <!-- Другие свойства того же домена -->
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Другие свойства класса @Model.Property.Domain.NamespacedId()</h6>
            </div>
            <div class="card-body">
                @{
                    var otherProperties = Model.Property.Domain.Properties.Values
                    .Where(p => p.Id != Model.Property.Id)
                    .ToList();
                }

                @if (otherProperties.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var prop in otherProperties)
                        {
                            <a href="/@prop.Href()"
                               class="list-group-item list-group-item-action py-2">
                                <div class="d-flex justify-content-between">
                                    <span>@prop.Name</span>
                                    <small class="text-muted">@prop.Range.NamespacedId()</small>
                                </div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">У класса нет других свойств</p>
                }
            </div>
        </div>
    </div>
</div>
